<% layout("/layouts/boilerplate.ejs") %>
<div class="row">
  <div class="col-8 offset-2">
    <h2>Edit Your Listing</h2>
    <form
      method="POST"
      action="/listings/<%= listing._id %>?_method=PUT"
      novalidate
      class="needs-validation"
      enctype="multipart/form-data"
    >
      <div>
        <label for="title" class="form-label">Title</label>
        <input
          name="listing[title]"
          class="form-control"
          value="<%= listing.title %>"
          type="text"
          required
        />
        <div class="invalid-feedback">Title looks good</div>
      </div>
      <br />
      <div>
        <label for="description" class="form-label">Description</label>
        <textarea
          name="listing[description]"
          rows="5"
          cols="28"
          value="<%= listing.title %>"
          class="form-control"
          required
        >
<%= listing.description %></textarea
        >
        <div class="invalid-feedback">Enter a short description</div>
      </div>
      <br />
      <div> 
        <p class="mb-2">Original Listing Image</p>
        <img
          src="<%= originalUrl %> "
          style="width: 300px; height: 200px; object-fit: cover"
        />
      </div>
      <br />
      <div>
        <label for="image" class="form-label">Upload New Image</label>
        <input name="listing[image]" class="form-control" type="file" />
      </div>

      <br />
      <div>
        <label for="price" class="form-label">Price</label>
        <input
          name="listing[price]"
          class="form-control"
          value="<%= listing.price %>"
          type="number"
          required
        />
        <div class="invalid-feedback">Enter a valid price</div>
      </div>
      <br />
      <div class="row">
        <div class="col-6">
          <label for="location" class="form-label">Location</label>
          <input
            name="listing[location]"
            class="form-control"
            value="<%= listing.location %>"
            type="text"
            required
          />
          <div class="invalid-feedback">Location name should be valid</div>
        </div>

        <br />
        <div class="col-6">
          <label for="country" class="form-label">Country</label>
          <input
            name="listing[country]"
            class="form-control"
            value="<%= listing.country %>"
            type="text"
            required
          />
          <div class="invalid-feedback">Country name should be valid</div>
        </div>
      </div>
      <br />

      <button class="btn btn-dark edit-btn">Update List</button>
    </form>
  </div>
</div>
